# ==============================================================================
# 🚀 Multimodal AI Interview Evaluator — Environment Configuration
# ==============================================================================
# This is an example environment file. 
# Copy this to `.env` in your project root or `backend/.env` as appropriate.
# NEVER commit your actual `.env` file containing secrets!
# ==============================================================================

# ── 1. Frontend Configuration ─────────────────────────────────────────────────
# The base URL where the Vite frontend will look for the FastAPI backend.
# Default: http://127.0.0.1:8000/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api


# ── 2. Backend Server Configuration ───────────────────────────────────────────
# Defines where local PyTorch/TensorFlow weights are stored.
# Default: ./backend/weights/
MODEL_WEIGHTS_PATH=./backend/weights/


# ── 3. Database & Authentication (Required for full usage) ────────────────────
# MongoDB Atlas Connection String
# Purpose: Persists users, sessions, historical telemetry, and RAG coaching documents.
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/
MONGODB_URI=

# JWT Signing Secret
# Purpose: Secures authentication tokens. Must be a strong, unpredictable 256-bit string.
# Generate via CLI: `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET_KEY=

# Optional JWT Overrides
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7


# ── 4. RAG Coaching LLM Integrations (Provide at least one) ───────────────────
# Purpose: Powers the AI Interview Mentor and Executive Summary generation.
# Note: The system will automatically detect which key is present and route accordingly.

# Groq API (Recommended for ultra-fast Llama-3 inference)
GROQ_API_KEY=

# OpenAI API (GPT-4o / GPT-4o-mini)
OPENAI_API_KEY=

# Google Gemini API (Gemini 1.5 Pro)
GEMINI_API_KEY=
